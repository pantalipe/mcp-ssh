# mcp-ssh — environment variables
# Copy this file to .env — never commit .env to git.

# VPS connection — use the 'panda' user directly
MCP_SSH_HOST=your.vps.ip.or.domain
MCP_SSH_PORT=22
MCP_SSH_USER=panda

# Dedicated SSH key (Ed25519) — generated by install.bat
MCP_SSH_KEY_PATH=C:\Users\panta\.ssh\mcp_ssh_ed25519

# Passphrase for the key (recommended)
MCP_SSH_KEY_PASSPHRASE=

# Systemd services allowed for status/restart (nginx managed via sudo)
MCP_SSH_ALLOWED_SERVICES=nginx

# pm2 app names allowed for status/restart/logs
MCP_SSH_ALLOWED_PM2=pandapoints-dapp

# screen session names allowed for log inspection
# Sessions must be started with: screen -L -Logfile ~/logs/<name>.log -S <name>
MCP_SSH_ALLOWED_SCREENS=telegram-bot

# Absolute repo paths on the VPS allowed for git pull/status
MCP_SSH_ALLOWED_REPOS=/home/panda/pandapoints-dapp,/home/panda/telegram-bot
