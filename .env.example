# mcp-ssh — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# VPS connection
MCP_SSH_HOST=your.vps.ip.or.domain
MCP_SSH_PORT=22
MCP_SSH_USER=claude-agent

# Path to the dedicated SSH private key (Ed25519 recommended)
MCP_SSH_KEY_PATH=C:\Users\panta\.ssh\mcp_ssh_ed25519

# Passphrase for the key above (leave empty if key has no passphrase)
MCP_SSH_KEY_PASSPHRASE=

# Comma-separated list of systemd services allowed for status/restart/logs
MCP_SSH_ALLOWED_SERVICES=telegram-bot,pandapoints-dapp,nginx

# Comma-separated list of repo absolute paths allowed for git pull/status
MCP_SSH_ALLOWED_REPOS=/home/claude-agent/pandapoints-dapp,/home/claude-agent/telegram-bot
