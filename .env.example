# mcp-ssh — environment variables
# Copy this file to .env — never commit .env to git.

# VPS connection
MCP_SSH_HOST=191.96.1.29
MCP_SSH_PORT=22
MCP_SSH_USER=panda

# Dedicated SSH key (Ed25519) — generated by install.bat
MCP_SSH_KEY_PATH=C:\Users\panta\.ssh\mcp_ssh_ed25519

# Passphrase for the key (recommended)
MCP_SSH_KEY_PASSPHRASE=

# Systemd services (nginx managed via sudo)
MCP_SSH_ALLOWED_SERVICES=nginx

# pm2 app name (dapp runs as 'pp')
MCP_SSH_ALLOWED_PM2=pp

# screen session name (bot runs as 'bot')
MCP_SSH_ALLOWED_SCREENS=bot

# Repo paths on the VPS allowed for git pull/status
MCP_SSH_ALLOWED_REPOS=/home/panda/pp

# Extra command aliases for ssh_run_command (JSON object, optional).
# Built-in aliases cover the most common ops — add extras here if needed.
# Format: {"alias-name": "shell command"}
# Example: MCP_SSH_ALLOWED_COMMANDS={"journalctl-boot": "journalctl -b --no-pager | tail -50"}
MCP_SSH_ALLOWED_COMMANDS=
